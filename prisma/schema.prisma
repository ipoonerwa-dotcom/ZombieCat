// ZombiesCat Store — data model (PostgreSQL: Neon/Supabase, works local + Vercel).
// Catalog lives in code (lib/products.ts). Orders snapshot product name/price at buy time,
// so there is no Product table to keep in sync. PII (address/email/phone) lives ONLY here.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id            String   @id @default(cuid())
  orderNo       String   @unique                 // human ref
  orderRef      String   @unique                 // keccak256(orderNo) — the on-chain binding
  buyerAddress  String                            // wallet that pays / burns
  status        String   @default("pending")      // pending | paid | fulfilled | cancelled
  chainId       Int      @default(4663)

  // money
  usdCents      Int                               // goods subtotal in USD cents (snapshot)
  shipUsdCents  Int      @default(0)
  totalUsdCents Int
  tokenAmount   String                            // quoted $ZCAT amount, wei (string)
  tokenRate     String   @default("0")            // ZCAT-per-USD used at quote time
  txHash        String   @default("")
  demoPaid      Boolean  @default(false)          // true = marked paid without a real on-chain burn
  paidAt        DateTime?

  // contact + shipping (PII — off-chain only)
  recipient     String   @default("")
  email         String   @default("")
  phone         String   @default("")
  country       String   @default("")
  region        String   @default("")
  city          String   @default("")
  addressLine   String   @default("")
  postalCode    String   @default("")
  shipKind      String   @default("domestic_free") // domestic_free | overseas_paid
  note          String   @default("")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items OrderItem[]

  @@index([buyerAddress])
  @@index([status])
}

model OrderItem {
  id           String @id @default(cuid())
  orderId      String
  order        Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  slug         String
  nameSnap     String
  unitUsdCents Int
  qty          Int

  @@index([orderId])
}

// Admin-editable key/values: zcat_per_usd, token_address, store_address, overseas_ship_cents,
// raffle_status, raffle_deadline, raffle_tokens_per_ticket, raffle_issued, raffle_prize_slug,
// raffle_prize_count, raffle_winning_number, raffle_winner_address, raffle_seed_block, raffle_seed_hash
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// HODL raffle: 1 numbered ticket per N tokens held. Tickets are committed by the holder
// (choose how many), each maps to a contiguous number range in `ranges` (JSON [[start,end],...]).
// One winning number is drawn at the deadline. Shipping (PII) lives ONLY here, off-chain.
model RaffleParticipant {
  id          String   @id @default(cuid())
  address     String   @unique              // lower-cased wallet
  tickets     Int      @default(0)          // total committed ticket count
  ranges      String   @default("[]")       // JSON [[start,end],...] inclusive, 1-based
  balanceWei  String   @default("0")        // token balance snapshot at last entry
  chainId     Int      @default(4663)

  // shipping (PII — off-chain only), collected at entry so the winner can be shipped
  recipient   String   @default("")
  phone       String   @default("")
  country     String   @default("")
  region      String   @default("")
  city        String   @default("")
  addressLine String   @default("")
  postalCode  String   @default("")
  note        String   @default("")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tickets])
}
