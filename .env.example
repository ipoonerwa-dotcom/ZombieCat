# ---- ZombiesCat Store — environment variables ----
# Copy to .env for local dev; set the same on Vercel (Project → Settings → Environment Variables).

# PostgreSQL connection string (Neon / Supabase). Required.
# Neon: create a project → copy the "Pooled connection" string, add ?sslmode=require if missing.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Admin console (/admin) — CHANGE THESE for production.
ADMIN_PASSWORD="change-me-to-something-strong"
ADMIN_SECRET="random-long-string-for-cookie-signing"

# ---- On-chain (optional; leave empty = demo checkout, no real burn) ----
# Fill once $ZCAT + the Store contract are deployed on Robinhood Chain, or set them from /admin.
NEXT_PUBLIC_TOKEN_ADDRESS=""
NEXT_PUBLIC_STORE_ADDRESS=""
NEXT_PUBLIC_TOKEN_DECIMALS="18"
NEXT_PUBLIC_TOKEN_SYMBOL="ZCAT"
NEXT_PUBLIC_CHAIN_ID="4663"

# Optional: dedicated RPC for server-side burn verification (falls back to the public Robinhood RPC).
# SERVER_RPC_URL=""
